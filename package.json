{
  "name": "fable-wars",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "A fantasy browser RTS with base building, crystal economies, cinematic skirmishes, and Crystal Rush battles.",
  "homepage": "https://fablewars.vercel.app/",
  "repository": {
    "type": "git",
    "url": "https://github.com/twerpygeek/fable-wars.git"
  },
  "bugs": {
    "url": "https://github.com/twerpygeek/fable-wars/issues"
  },
  "keywords": [
    "browser-game",
    "rts",
    "strategy",
    "canvas",
    "typescript",
    "vite",
    "fable-wars"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test:headless": "tsx tests/headless.ts",
    "test:art": "tsx tests/artIdentity.ts",
    "test:crystal-rush": "tsx tests/crystalRush.ts",
    "test:multiplayer": "tsx tests/multiplayer.ts && tsx tests/multiplayerProtocol.ts && tsx tests/multiplayerClient.ts && tsx tests/onlineBattleClient.ts",
    "test:balance": "tsx tests/balance.ts --reps 2 --maxMin 35",
    "test:guidance": "tsx tests/guidance.ts"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "tsx": "^4.19.0",
    "typescript": "~5.6.3",
    "vite": "^6.0.0"
  },
  "dependencies": {
    "zzfx": "^1.3.2"
  }
}
